# ---------- Initialization ----------
units           metal
atom_style      atomic
atom_modify     map yes
newton          on

boundary        p p p
variable        POT getenv MACE_MPA_0_MEDIUM

lattice         bcc 3.5
region          box block 0 2 0 2 0 2
create_box      1 box
create_atoms    1 box
mass            1 55.845

# ---------- Interatomic Potential ----------
pair_style      mliap unified ${POT} 0
pair_coeff      * *  Fe

# ---------- Settings ----------
neighbor        2.0 bin
neigh_modify    delay 0 every 1 check yes

dump            traj all dcd 1 trajectory.dcd
run             0
