#!/usr/bin/python3
import json
import sys
import os
from pathlib import Path
from collections import defaultdict

FIELDS = ("input_tokens", "output_tokens", "total_tokens", "total_cost")


def read_paths():
    paths = []

    if not sys.stdin.isatty():
        for line in sys.stdin:
            p = line.strip()
            if p:
                paths.append(p)

    paths.extend(sys.argv[1:])

    if not paths:
        paths = ["."]
    return [Path(p) for p in paths]


def aggregate(paths):
    roles = defaultdict(lambda: {k: 0 for k in FIELDS})
    total = {k: 0 for k in FIELDS}
    sources = []

    for root in paths:
        for dirpath, _, filenames in os.walk(root, followlinks=True):
            for name in filenames:
                if not name.endswith(".audit.jsonl"):
                    continue

                file = Path(dirpath) / name
                abspath = str(file.resolve())
                sources.append(abspath)

                with file.open() as f:
                    for line in f:
                        if not line.strip():
                            continue

                        rec = json.loads(line)
                        role = rec.get("role", "unknown")
                        entry = roles[role]

                        for k in FIELDS:
                            v = rec.get(k, 0)
                            entry[k] += v
                            total[k] += v

    result = dict(roles)
    result["total"] = total
    result["sources"] = sources
    return result


def main():
    paths = read_paths()
    result = aggregate(paths)
    print(json.dumps(result, indent=2))


if __name__ == "__main__":
    main()
